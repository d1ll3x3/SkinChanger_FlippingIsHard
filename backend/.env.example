# Copy to .env and adjust. For local development you can leave everything unset:
# the app falls back to local disk storage under ./storage.

# --- Production storage: GitHub repository (free, no credit card) ---
# When BOTH are set, the app stores skins/charms in this PUBLIC repo via the GitHub
# Contents API instead of local disk. The mod then downloads straight from
# raw.githubusercontent.com/<GITHUB_REPO>/<GITHUB_BRANCH>/...
#
# GITHUB_REPO=youruser/charm-skins-data
# GITHUB_TOKEN=github_pat_xxx   (fine-grained PAT, Contents: Read and write on that repo)
# GITHUB_BRANCH=main

# --- Local-only storage folder (used when GitHub vars are unset) ---
STORAGE_DIR=storage

# Size limits (bytes). Charm limit kept under the GitHub Contents API comfort zone.
MAX_IMAGE_BYTES=16777216
MAX_CHARM_BYTES=26214400
